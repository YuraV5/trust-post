generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRoles {
  USER      @map("user")
  ADMIN     @map("admin")
  MODERATOR @map("moderator")

  @@map("user_roles")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique @db.VarChar(255)
  name             String            @db.VarChar(128)
  password         String?
  photoUrl         String?           @map("photo_url") @db.VarChar(512)
  role             UserRoles         @default(USER)
  isActive         Boolean           @default(true) @map("is_active")
  isEmailVerified  Boolean           @default(false) @map("is_email_verified")
  createdByAdmin   Boolean           @default(false) @map("created_by_admin")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  sessions         Session[]
  posts            Post[]
  userRolePeriods  UserRolePeriod[]
  postReviews      PostReview[]
  comments         Comment[]
  commentLikes     CommentLike[]
  postLikes        PostLike[]
  chatMembers      ChatMember[]
  messagesSent     Message[]
  privateChats1    PrivateChat[]     @relation("private_chat_user1")
  privateChats2    PrivateChat[]     @relation("private_chat_user2")
  providerAccounts ProviderAccount[]

  @@index([createdAt])
  @@index([role])
  @@index([isEmailVerified, createdAt])
  @@map("users")
}

enum AuthProvider {
  GOOGLE @map("google")
  GITHUB @map("github")

  @@map("auth_providers")
}

model ProviderAccount {
  id             String       @id @default(uuid())
  provider       AuthProvider
  providerId     String       @map("provider_id") @db.VarChar(255)
  userId         String       @map("user_id")
  providerData   Json?        @map("provider_data") @db.Json
  accessToken    String?      @map("access_token") @db.VarChar(512)
  refreshToken   String?      @map("refresh_token") @db.VarChar(512)
  tokenExpiresAt DateTime?    @map("token_expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("provider_accounts")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  deviceId         String    @map("device_id") @db.VarChar(255)
  userAgent        String    @map("user_agent") @db.VarChar(512)
  ip               String    @db.VarChar(45)
  lastUsedAt       DateTime? @map("last_used_at")
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@map("sessions")
}

model UserRolePeriod {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(128)
  userId      String    @map("user_id")
  role        UserRoles
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  changedById String    @map("changed_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([role])
  @@index([endDate])
  @@index([userId, endDate])
  @@map("user_role_periods")
}

enum PostStatus {
  DRAFT          @map("draft")
  PENDING_REVIEW @map("pending_review")
  APPROVED       @map("approved")
  REJECTED       @map("rejected")
  BLOCKED        @map("blocked")
  ARCHIVED       @map("archived")
  COMPLETED      @map("completed")

  @@map("post_statuses")
}

enum PostReviewStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")

  @@map("post_review_statuses")
}

enum Currencies {
  UAH @map("uah")

  @@map("currencies")
}

enum PaymentStatus {
  PENDING @map("pending")
  SUCCESS @map("success")
  FAILED  @map("failed")
  EXPIRED @map("expired")

  @@map("payment_statuses")
}

enum PaymentProvider {
  WAYFORPAY @map("wayforpay")

  @@map("payment_providers")
}

model Payment {
  id                 String        @id @default(uuid())
  postId             Int           @map("post_id")
  userId             String?       @map("user_id")
  amount             Decimal       @db.Decimal(12, 2)
  currency           Currencies    @default(UAH)
  status             PaymentStatus @default(PENDING)
  message            String?       @db.Text // rewite field name to better reflect its purpose, e.g. failureReason or statusMessage
  referencePaymentId String        @map("reference_payment_id") @db.VarChar(255)
  lastAttemptId      String?       @map("last_attempt_id") @db.VarChar(255)
  confirmedAt        DateTime?     @map("confirmed_at")
  expiredAt          DateTime?     @map("expired_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  post            Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  lastAttempt     PaymentAttempt?  @relation("PaymentLastAttempt", fields: [lastAttemptId], references: [id], onDelete: SetNull)
  paymentAttempts PaymentAttempt[] @relation("PaymentAttempts")

  @@index([postId])
  @@index([userId])
  @@index([status])
  @@index([lastAttemptId])
  @@index([referencePaymentId])
  @@map("payments")
}

model PaymentAttempt {
  id                String          @id @default(uuid())
  paymentId         String          @map("payment_id")
  provider          PaymentProvider @map("provider")
  providerPaymentId String?         @map("provider_payment_id") @db.VarChar(255)
  status            PaymentStatus   @default(PENDING)
  providerResponse  Json?           @map("provider_response") @db.Json
  message           String?         @db.Text // rewrite field name to better reflect its purpose, e.g. failureReason or statusMessage
  createdAt         DateTime        @default(now()) @map("created_at")

  payment        Payment   @relation("PaymentAttempts", fields: [paymentId], references: [id], onDelete: Cascade)
  paymentLastRef Payment[] @relation("PaymentLastAttempt")

  @@unique([provider, providerPaymentId])
  @@index([paymentId])
  @@index([paymentId, createdAt])
  @@index([provider])
  @@index([providerPaymentId])
  @@map("payment_attempts")
}

model Post {
  id                 Int        @id @default(autoincrement())
  title              String     @db.VarChar(255)
  content            String     @db.Text
  targetAmount       Decimal    @map("target_amount") @db.Decimal(12, 2)
  currentAmount      Decimal    @default(0) @map("current_amount") @db.Decimal(12, 2)
  currency           Currencies @default(UAH)
  referencePaymentId String     @unique @map("reference_payment_id") @db.VarChar(255)
  targetDate         DateTime   @map("target_date")
  status             PostStatus @default(DRAFT)
  statusReason       String?    @map("status_reason") @db.Text // change field name to better reflect its purpose
  authorId           String     @map("author_id")
  totalComments      Int        @default(0) @map("total_comments")
  totalLikes         Int        @default(0) @map("total_likes")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")

  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  postReviews PostReview[]
  comments    Comment[]
  likes       PostLike[]
  files       PostFile[]
  chat        Chat?
  payments    Payment[]

  @@index([status])
  @@index([authorId])
  @@index([createdAt])
  @@index([referencePaymentId])
  @@map("posts")
}

model PostReview {
  id           Int              @id @default(autoincrement())
  postId       Int              @map("post_id")
  reviewedById String           @map("reviewed_by_id")
  status       PostReviewStatus @default(PENDING)
  isActive     Boolean          @default(true) @map("is_active")
  reviewReason String?          @map("review_reason") @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")

  reviewedBy User? @relation(fields: [reviewedById], references: [id], onDelete: SetNull)
  post       Post  @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([reviewedById])
  @@index([createdAt])
  @@map("post_reviews")
}

enum CommentStatus {
  VISIBLE
  DELETED

  @@map("comment_statuses")
}

model Comment {
  id         Int           @id @default(autoincrement())
  postId     Int           @map("post_id")
  authorId   String        @map("author_id")
  content    String        @db.Text
  status     CommentStatus @default(VISIBLE)
  totalLikes Int           @default(0) @map("total_likes")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  author User          @relation(fields: [authorId], references: [id])
  post   Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes  CommentLike[]

  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_likes")
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

enum FileProvider {
  CLOUDINARY @map("cloudinary")

  @@map("file_providers")
}

model PostFile {
  id           Int          @id @default(autoincrement())
  url          String       @db.VarChar(512)
  postId       Int          @map("post_id")
  uploadedById String       @map("uploaded_by_id")
  storageKey   String       @map("storage_key") @db.VarChar(255)
  provider     FileProvider @map("provider")
  mimeType     String       @map("mime_type") @db.VarChar(255)
  mainImage    Boolean      @default(false) @map("main_image")
  size         Int          @map("size")
  metadata     Json?        @map("metadata") @db.Json
  originalName String       @map("original_name") @db.VarChar(255)
  createdAt    DateTime     @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, provider, storageKey])
  @@index([postId])
  @@index([uploadedById])
  @@index([provider])
  @@index([postId, mainImage])
  @@index([createdAt])
  @@map("post_files")
}

// ========================
// Chat Models
// ========================

enum ChatType {
  PRIVATE @map("private")
  GROUP   @map("group")
  POST    @map("post")

  @@map("chat_types")
}

model Chat {
  id        String   @id @default(uuid())
  type      ChatType @default(PRIVATE)
  title     String?  @db.VarChar(255)
  postId    Int?     @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     ChatMember[]
  messages    Message[]
  PrivateChat PrivateChat?
  post        Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId])
  @@index([type])
  @@index([title])
  @@index([postId])
  @@map("chats")
}

model PrivateChat {
  id        String   @id @default(uuid())
  chatId    String   @unique @map("chat_id")
  user1Id   String   @map("user1_id")
  user2Id   String   @map("user2_id")
  createdAt DateTime @default(now()) @map("created_at")

  chat  Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user1 User @relation("private_chat_user1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("private_chat_user2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("private_chats")
}

model ChatMember {
  id       String   @id @default(uuid())
  chatId   String   @map("chat_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@map("chat_members")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  senderId  String   @map("sender_id")
  content   String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chat   Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  files  MessageFile[]

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model MessageFile {
  id           String       @id @default(uuid())
  messageId    String       @map("message_id")
  url          String       @db.VarChar(512)
  storageKey   String       @map("storage_key") @db.VarChar(255)
  provider     FileProvider @map("provider")
  mimeType     String       @map("mime_type") @db.VarChar(255)
  size         Int          @map("size")
  originalName String       @map("original_name") @db.VarChar(255)
  createdAt    DateTime     @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([provider])
  @@index([createdAt])
  @@map("message_files")
}
