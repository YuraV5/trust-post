{
  "name": "trust-post",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:dev": "docker compose --env-file .env.development up -d",
    "mgr:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "mgr:deploy": "prisma migrate deploy",
    "pr:gen": "prisma generate",
    "docker:prod": "docker build -t trust-post:latest . && docker-compose -f docker-compose.prod.yml up --abort-on-container-exit --remove-orphans",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down -v",
    "seed:users": "ts-node tools/seeds.ts users",
    "seed:posts": "ts-node tools/seeds.ts posts",
    "seed:comments": "ts-node tools/seeds.ts comments",
    "seed:full": "ts-node tools/seeds.ts full",
    "seed:admin": "npm run seed:users"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.16",
    "@prisma/client": "^6.4.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.67.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "joi": "^18.0.2",
    "logform": "^2.7.0",
    "prisma": "^6.4.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/logform": "^1.2.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.11",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.{ts,js}",
      "!**/*.module.{ts,js}",
      "!**/controllers/**",
      "!**/repositories/**",
      "!**/dto/**",
      "!**/swagger/**",
      "!**/index.{ts,js}",
      "!**/main.{ts,js}",
      "!**/app/**",
      "!**/config/**",
      "!**/core/**",
      "!**/__mock__/**",
      "!**/database/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!uuid)/"
    ]
  }
}
