# Trust Post environment configuration example

# App
NODE_ENV=development
PORT=3001
DOCKERHUB_USERNAME=yura35
CORS_ALLOW_ORIGIN=http://localhost:5173
WS_CORS_ALLOW_ORIGIN=http://localhost:5173
TRUST_PROXY=false
SWAGGER_ENABLED=true
SERVICE_NAME=trust-post
LOGGER_LEVEL=info
LOGGER_CONSOLE_ENABLED=true
LOGGER_FILE_ENABLED=false
LOGGER_FILE_MAX_SIZE_MB=10
LOGGER_FILE_MAX_FILES=5
FRONTEND_URL=http://localhost:5173
SERVICE_URL=http://localhost:3001

# Idempotency
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_INTERCEPTOR_TTL=300

# Throttling
THROTTLE_GLOBAL_LIMIT=120
THROTTLE_GLOBAL_TTL_MS=60000
THROTTLE_BLOCK_TTL_MS=300000
THROTTLE_PAYMENT_ANONYMOUS_LIMIT=5
THROTTLE_PAYMENT_ANONYMOUS_TTL_MS=60000
THROTTLE_PAYMENT_ANONYMOUS_BLOCK_TTL_MS=300000
THROTTLE_PAYMENT_WEBHOOK_LIMIT=30
THROTTLE_PAYMENT_WEBHOOK_TTL_MS=60000
THROTTLE_PAYMENT_WEBHOOK_BLOCK_TTL_MS=300000
MESSAGES_CLEANUP_BATCH_LIMIT=200

# Cache TTL
CACHE_POSTS_LIST_TTL_SECONDS=30
CACHE_POST_BY_ID_TTL_SECONDS=30
CACHE_COMMENTS_LIST_TTL_SECONDS=30

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trust_post
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trust_post

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300
REDIS_MAX_RETRIES=5
REDIS_RETRY_DELAY_MS=2000
REDIS_GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000

# JWT and session
JWT_ACCESS_SECRET=your_access_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRATION=7d
JWT_OAUTH_STATE_SECRET=your_oauth_state_secret
JWT_ISSUER=trust-post-service
SESSION_EXPIRES=7d

# Email
## https://resend.com/
EMAIL_RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=no-reply@example.com

# Cloudinary
## https://console.cloudinary.com/
CLOUDINARY_API_KEY=xxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxx
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Wayforpay
## https://wayforpay.com/en/
WAYFORPAY_MERCHANT_ACCOUNT=test_merch_n1
WAYFORPAY_MERCHANT_DOMAIN_NAME=example.com
WAYFORPAY_SECRET_KEY=flk3409refn54t54t*FNJRET
WAYFORPAY_API_URL=https://api.wayforpay.com/api
WAYFORPAY_WEBHOOK_URL=https://api.example.com/api/v1/payments/webhook
WAYFORPAY_RETURN_URL=https://frontend.example.com/payment-result
WAYFORPAY_ORDER_EXPIRES_AT=3600

# Google OAuth
## https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=client_secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_OAUTH_API_KEY=api_key

# AI moderation
## https://aistudio.google.co
GEMINI_API_KEY=

# Monitoring (Grafana)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_in_prod