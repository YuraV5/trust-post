# Environment configuration example

# App settings
NODE_ENV=development
PORT=3001
CORS_ALLOW_ORIGIN=http://localhost:3000
WS_CORS_ALLOW_ORIGIN=http://localhost:3000
TRUST_PROXY=false
SWAGGER_ENABLED=true
SERVICE_NAME=trust-post
LOGGER_LEVEL=info
FRONTEND_URL=http://localhost:3000
SERVICE_URL=http://localhost:3001
THROTTLE_GLOBAL_LIMIT=120
THROTTLE_GLOBAL_TTL_MS=60000
THROTTLE_BLOCK_TTL_MS=300000

# Database settings
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trust_post
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trust_post

# Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=12345
REDIS_TTL=300
REDIS_MAX_RETRIES=5
REDIS_RETRY_DELAY_MS=2000
REDIS_GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000

# JWT settings
JWT_ACCESS_SECRET=your_access_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=trust-post
SESSION_EXPIRES=7d

# Email settings
EMAIL_RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=no-reply@example.com

# Cloudinary settings
CLOUDINARY_API_KEY=xxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxx
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Wayforpay settings
WAYFORPAY_MERCHANT_ACCOUNT=merchant_account
WAYFORPAY_MERCHANT_DOMAIN_NAME=example.com
WAYFORPAY_SECRET_KEY=secret_key
WAYFORPAY_API_URL=https://api.wayforpay.com/api
WAYFORPAY_WEBHOOK_URL=https://api.example.com/api/v1/payments/webhook
WAYFORPAY_RETURN_URL=https://frontend.example.com/payment/result
WAYFORPAY_ORDER_EXPIRES_AT=3600

# Google OAuth settings
GOOGLE_OAUTH_CLIENT_ID=client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=client_secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_OAUTH_API_KEY=api_key

# Comment moderation
MCP_MODERATION_BASE_URL=http://localhost:3003
MCP_MODERATION_PROVIDER=gemini
MCP_MODERATION_TIMEOUT_MS=5000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta