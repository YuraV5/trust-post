{
  "name": "trust-post",
  "version": "1.1.1",
  "description": "Pet project for my CV. Social media platform with AI features built with NestJS and Prisma.",
  "author": "Vakula Yuriy <1vakyura1@gmail.com>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.test -- jest --config ./test/jest-e2e.json",
    "docker:dev": "docker compose -f docker-compose.local.yml --env-file .env up -d",
    "docker:dev:down": "docker compose -f docker-compose.local.yml --env-file .env down",
    "docker:prod": "docker compose --env-file .env -f docker-compose.yml --profile monitoring pull app && docker compose --env-file .env -f docker-compose.yml --profile monitoring up -d",
    "docker:prod:down": "docker compose --env-file .env -f docker-compose.yml --profile monitoring down",
    "docker:prod:migrate": "docker compose --env-file .env -f docker-compose.yml --profile monitoring exec -T app npm run mgr:deploy",
    "docker:prod:seed": "docker compose --env-file .env -f docker-compose.yml --profile monitoring exec -T app npm run seed:full:prod",
    "docker:prod-local": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod-local.yml --profile monitoring up -d --build",
    "docker:prod-local:down": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod-local.yml --profile monitoring down",
    "docker:prod-local:migrate": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod-local.yml --profile monitoring exec -T app npm run mgr:deploy",
    "docker:prod-local:seed": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod-local.yml --profile monitoring exec -T app npm run seed:full:prod",
    "mgr:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "mgr:deploy": "prisma migrate deploy",
    "pr:gen": "prisma generate",
    "seed:users": "ts-node tools/seeds.ts users",
    "seed:posts": "ts-node tools/seeds.ts posts",
    "seed:comments": "ts-node tools/seeds.ts comments",
    "seed:full": "ts-node tools/seeds.ts full",
    "seed:users:prod": "node dist/tools/seeds.js users",
    "seed:posts:prod": "node dist/tools/seeds.js posts",
    "seed:comments:prod": "node dist/tools/seeds.js comments",
    "seed:full:prod": "node dist/tools/seeds.js full",
    "seed:admin": "npm run seed:users"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.16",
    "@prisma/client": "^6.4.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.67.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "joi": "^18.0.2",
    "logform": "^2.7.0",
    "prisma": "^6.4.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^11.11.0",
    "@testcontainers/redis": "^11.13.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/logform": "^1.2.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.11",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/main.ts",
      "!src/**/*.module.ts",
      "!src/**/*.controller.ts",
      "!src/**/*.gateway.ts",
      "!src/**/*.decorator.ts",
      "!src/**/*.config.ts",
      "!src/**/*.factory.ts",
      "!src/**/*.repo.ts",
      "!src/**/*.error.ts",
      "!src/common/decorators/**",
      "!src/common/guards/**",
      "!src/**/controllers/**",
      "!src/**/dto/**",
      "!src/**/dtos/**",
      "!src/**/swagger/**",
      "!src/**/interfaces/**",
      "!src/**/types/**",
      "!src/**/repo/**",
      "!src/**/repos/**",
      "!src/**/providers/**",
      "!src/**/jobs/**",
      "!src/**/index.ts",
      "!src/**/__mock__/**",
      "!src/app/**",
      "!src/configs/**",
      "!src/infrastructure/**",
      "!src/shared/logger/**"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/test/",
      "/unit-tests/",
      "\\.d\\.ts$"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!uuid)/"
    ]
  }
}
